{
  "name": "@t3tools/tui",
  "version": "0.0.27",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --packages=external --format=esm --platform=node --jsx=automatic --outfile=dist/index.js",
    "typecheck": "tsgo --noEmit",
    "test": "vp test run --passWithNoTests"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "@t3tools/client-runtime": "workspace:*",
    "@t3tools/contracts": "workspace:*",
    "@xterm/headless": "^5.5.0",
    "effect": "catalog:",
    "ink": "^6.3.1",
    "react": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "~19.2.14",
    "esbuild": "^0.27.7",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": "^22.16 || ^23.11 || >=24.10"
  }
}
